# Stage 1: Build
FROM node:24-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci --ignore-scripts
COPY . .
RUN npx nx sync
RUN npx nx run-many --target=build --projects=shell,weather-app,weatheredit-app,admin-app --configuration=production --parallel=1

# Stage 2: Serve
FROM nginx:alpine AS runner
COPY nginx/nginx.conf /etc/nginx/nginx.conf
RUN mkdir -p /var/log/nginx && chown nginx:nginx /var/log/nginx
RUN sed -i 's|application/javascript\s*js;|application/javascript js mjs;|' /etc/nginx/mime.types
COPY --from=builder /app/dist/apps/shell /usr/share/nginx/html/shell
COPY --from=builder /app/dist/apps/weather-app /usr/share/nginx/html/weather-app
COPY --from=builder /app/dist/apps/weatheredit-app /usr/share/nginx/html/weatheredit-app
COPY --from=builder /app/dist/apps/admin-app /usr/share/nginx/html/admin-app
EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
