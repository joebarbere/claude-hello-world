{
  "title": "Weather API",
  "uid": "weather-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_requests_received_total{job=\"weather-api\"}[1m])",
          "legendFormat": "{{method}} {{path}} {{code}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Request Duration (p99)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"weather-api\"}[1m]))",
          "legendFormat": "p99 {{method}} {{path}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "In-Flight HTTP Requests",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "http_requests_in_progress{job=\"weather-api\"}",
          "legendFormat": "In-Flight"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Process Memory (MB)",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_working_set_bytes{job=\"weather-api\"} / 1024 / 1024",
          "legendFormat": "Working Set MB"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Nginx Active Connections",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nginx_connections_active{job=\"nginx\"}",
          "legendFormat": "Active"
        },
        {
          "expr": "nginx_connections_waiting{job=\"nginx\"}",
          "legendFormat": "Waiting"
        }
      ]
    }
  ]
}
