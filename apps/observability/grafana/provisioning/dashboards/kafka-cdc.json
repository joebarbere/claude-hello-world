{
  "title": "Kafka & CDC",
  "uid": "kafka-cdc",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "PostgreSQL Replication",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Replication Slot Lag",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_replication_slots_pg_wal_lsn_diff",
          "legendFormat": "{{slot_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Replication Slot Status",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_replication_slots_active",
          "legendFormat": "{{slot_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "INACTIVE", "color": "red" },
                "1": { "text": "ACTIVE", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "Debezium CDC",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Records Written (rate)",
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(kafka_connect_source_task_metrics_source_record_write_total{connector=\"weather-api-connector\"}[5m])",
          "legendFormat": "{{connector}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Poll Batch Avg Time",
      "gridPos": { "x": 8, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kafka_connect_source_task_metrics_poll_batch_avg_time_ms{connector=\"weather-api-connector\"}",
          "legendFormat": "{{connector}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Active Source Records",
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kafka_connect_source_task_metrics_source_record_active_count{connector=\"weather-api-connector\"}",
          "legendFormat": "{{connector}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Kafka Connect",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Connector Running Ratio",
      "gridPos": { "x": 0, "y": 19, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kafka_connect_connector_task_metrics_running_ratio{connector=\"weather-api-connector\"}",
          "legendFormat": "{{connector}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Connectors",
      "gridPos": { "x": 8, "y": 19, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kafka_connect_connect_worker_metrics_connector_count",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Failed Tasks",
      "gridPos": { "x": 16, "y": 19, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kafka_connect_connect_worker_metrics_connector_failed_task_count{connector=\"weather-api-connector\"}",
          "legendFormat": "{{connector}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    }
  ]
}
