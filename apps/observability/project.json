{
  "name": "observability",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/observability",
  "tags": [],
  "targets": {
    "podman-build-prometheus": {
      "executor": "nx:run-commands",
      "options": {
        "command": "podman build -t prometheus -f apps/observability/prometheus/Containerfile apps/observability/prometheus",
        "cwd": "{workspaceRoot}"
      }
    },
    "podman-build-grafana": {
      "executor": "nx:run-commands",
      "options": {
        "command": "podman build -t grafana -f apps/observability/grafana/Containerfile apps/observability/grafana",
        "cwd": "{workspaceRoot}"
      }
    },
    "podman-build-loki": {
      "executor": "nx:run-commands",
      "options": {
        "command": "podman build -t loki -f apps/observability/loki/Containerfile apps/observability/loki",
        "cwd": "{workspaceRoot}"
      }
    },
    "podman-build-promtail": {
      "executor": "nx:run-commands",
      "options": {
        "command": "podman build -t promtail -f apps/observability/promtail/Containerfile apps/observability/promtail",
        "cwd": "{workspaceRoot}"
      }
    },
    "podman-build-auth-proxy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "podman build -t auth-proxy -f apps/observability/auth-proxy/Containerfile apps/observability/auth-proxy",
        "cwd": "{workspaceRoot}"
      }
    },
    "podman-build-blackbox-exporter": {
      "executor": "nx:run-commands",
      "options": {
        "command": "podman build -t blackbox-exporter -f apps/observability/blackbox/Containerfile apps/observability/blackbox",
        "cwd": "{workspaceRoot}"
      }
    },
    "podman-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Observability images built'",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": [
        "podman-build-prometheus",
        "podman-build-grafana",
        "podman-build-loki",
        "podman-build-promtail",
        "podman-build-auth-proxy",
        "podman-build-blackbox-exporter"
      ]
    },
    "kube-up": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "podman system service --time=0 tcp:0.0.0.0:9999 &",
          "podman play kube k8s/observability-pod.yaml"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["podman-build"]
    },
    "kube-down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "podman play kube k8s/observability-pod.yaml --down || true",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
