{
  "name": "shell",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/shell/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:webpack-browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/shell",
        "index": "apps/shell/src/index.html",
        "main": "apps/shell/src/main.ts",
        "tsConfig": "apps/shell/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/shell/public"
          }
        ],
        "styles": ["apps/shell/src/styles.css"],
        "customWebpackConfig": {
          "path": "apps/shell/webpack.config.ts"
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "customWebpackConfig": {
            "path": "apps/shell/webpack.prod.config.ts"
          }
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/angular:module-federation-dev-server",
      "options": {
        "port": 4200,
        "publicHost": "http://localhost:4200",
        "proxyConfig": "apps/shell/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "shell:build:production"
        },
        "development": {
          "buildTarget": "shell:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "shell:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../coverage/apps/shell"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "shell:build",
        "port": 4200,
        "spa": true
      }
    },
    "build-all": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nx run-many --target=build --projects=shell,weather-app,weatheredit-app,admin-app --configuration=production --parallel=3"
      }
    },
    "podman-build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "podman build -t claude-hello-world -f Containerfile.nginx ."
        ],
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["build-all"]
    },
    "podman-up": {
      "executor": "nx:run-commands",
      "options": {
        "command": "podman run -d --name claude-hello-world -p 8080:8080 localhost/claude-hello-world:latest",
        "cwd": "{workspaceRoot}"
      }
    },
    "podman-down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "podman rm -f claude-hello-world",
        "cwd": "{workspaceRoot}"
      }
    },
    "kube-up": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "for img in postgres ory-kratos ory-kratos-init traefik weather-api claude-hello-world; do podman image exists localhost/$img:latest || { echo \"ERROR: missing image localhost/$img:latest — run the podman-build targets first\"; exit 1; }; done",
          "podman machine ssh 'sudo mkdir -p /var/log/traefik /var/log/nginx && sudo chmod 777 /var/log/traefik /var/log/nginx'",
          "podman play kube k8s/postgres-pod.yaml",
          "i=0; until podman run --rm localhost/postgres:latest pg_isready -h host.containers.internal -p 5432 -U appuser; do i=$((i+1)); [ $i -ge 30 ] && echo 'ERROR: postgres unreachable via host.containers.internal' && exit 1; echo 'waiting for postgres via host.containers.internal'; sleep 2; done",
          "podman play kube k8s/ory-kratos-pod.yaml",
          "podman play kube k8s/apps-pod.yaml"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["postgres:podman-build", "ory:podman-build", "traefik:podman-build", "weather-api:podman-build", "podman-build"]
    },
    "kube-down": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "podman play kube k8s/apps-pod.yaml --down || true",
          "podman play kube k8s/ory-kratos-pod.yaml --down || true",
          "podman play kube k8s/postgres-pod.yaml --down || true"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
